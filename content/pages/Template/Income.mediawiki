}}{{DISPLAYTITLE:{{{date|}}} {{#receiptscanner_truncate:{{{payer|}}}|30}}}}<div class="rs-entry">
<div class="rs-entry-receipt">{{#if:{{{file|}}}|[{{#receiptscanner_file_url:{{{file}}}}} [[File:{{{file}}}{{!}}frameless{{!}}450px{{!}}link={{!}}alt={{{file}}}]]]|<div class="rs-no-receipt">''{{int:receiptscanner-template-no-receipt}}''</div>}}</div>
<div class="rs-entry-fields">
<div class="rs-entry-card">
<div class="rs-entry-header">
<div class="rs-entry-party-block"><div class="rs-entry-label">{{int:receiptscanner-template-label-payer}}</div><div class="rs-entry-party-name">{{#if:{{{payer|}}}|[{{fullurl:Special:Ledger|kind=income&range=all&party={{urlencode:{{{payer}}}}}}} {{{payer}}}]|—}}</div></div>
<div class="rs-entry-total">{{#receiptscanner_format_amount:{{{total|0}}}|{{{currency|{{#receiptscanner_system_currency:}}}}}}}{{#ifeq:{{{currency|{{#receiptscanner_system_currency:}}}}}|{{#receiptscanner_system_currency:}}||<div class="rs-entry-total-converted">≈ {{#receiptscanner_format_amount:{{{total_system|{{{total|}}}}}}|{{#receiptscanner_system_currency:}}}}</div>}}</div>
</div>
<div class="rs-entry-row"><span class="rs-entry-label">{{int:receiptscanner-template-label-date}}</span><span class="rs-entry-value">{{#if:{{{date|}}}|[{{fullurl:Special:Ledger|kind=income&range=custom&from={{urlencode:{{{date}}}}}&to={{urlencode:{{{date}}}}}}} {{{date}}}]|—}}</span></div>
<div class="rs-entry-row"><span class="rs-entry-label">{{int:receiptscanner-template-label-subtotal}}</span><span class="rs-entry-value">{{#if:{{{subtotal|}}}|{{#receiptscanner_format_amount:{{{subtotal}}}|{{{currency|{{#receiptscanner_system_currency:}}}}}}}|—}}</span></div>
<div class="rs-entry-row"><span class="rs-entry-label">{{int:receiptscanner-template-label-tax}}</span><span class="rs-entry-value">{{#if:{{{tax|}}}|{{#receiptscanner_format_amount:{{{tax}}}|{{{currency|{{#receiptscanner_system_currency:}}}}}}}|—}}</span></div>
<div class="rs-entry-row"><span class="rs-entry-label">{{int:receiptscanner-template-label-fees}}</span><span class="rs-entry-value">{{#if:{{{fees|}}}|{{#receiptscanner_format_amount:{{{fees}}}|{{{currency|{{#receiptscanner_system_currency:}}}}}}}|—}}</span></div>
<div class="rs-entry-row"><span class="rs-entry-label">{{int:receiptscanner-template-label-payment-method}}</span><span class="rs-entry-value">{{#if:{{{payment_method|}}}|{{{payment_method}}}|—}}</span></div>
<div class="rs-entry-row"><span class="rs-entry-label">{{int:receiptscanner-template-label-category-income}}</span><span class="rs-entry-value">{{#if:{{{income_category|}}}|[{{fullurl:Special:Ledger|kind=income&range=all&category={{urlencode:{{{income_category}}}}}}} {{{income_category}}}]|—}}</span></div>
<div class="rs-entry-row"><span class="rs-entry-label">{{int:receiptscanner-template-label-assignee}}</span><span class="rs-entry-value">{{#if:{{{assignee|}}}|[{{fullurl:Special:Ledger|kind=income&range=all&assignee={{urlencode:{{{assignee}}}}}}} {{{assignee}}}]|<span class="rs-entry-pill">{{int:receiptscanner-template-company-wide}}</span>}}</span></div>
<div class="rs-entry-row"><span class="rs-entry-label">{{int:receiptscanner-template-label-notes}}</span><span class="rs-entry-value">{{#if:{{{notes|}}}|{{{notes}}}|—}}</span></div>
</div>
</div>
{{#if:{{{supplemental_files|}}}|<div class="rs-entry-supplemental">
'''{{int:receiptscanner-template-supporting-documents}}'''
<div class="rs-entry-supplemental-strip">{{#arraymap:{{{supplemental_files|}}}|,|@F@|[[File:@F@{{!}}thumb{{!}}120px{{!}}link={{#receiptscanner_file_url:@F@}}{{!}}@F@]]| }}</div>
</div>}}
</div>
